# Required: Google Gemini API key for chatbot AI features
GEMINI_API_KEY=

# Admin dashboard login (comma-separated emails allowed)
ADMIN_EMAILS=admin@example.com
ADMIN_PASSWORD=

# App URL used in email links (set to your Vercel URL in production)
APP_URL=http://localhost:3000

# SMTP email notifications (optional - ticket emails are skipped if not configured)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Email address that receives new-ticket admin alerts
SUPPORT_ALERT_EMAIL=

# Database
# Local development can omit DATABASE_URL to use ./dev.db, or set file:./dev.db.
# Production/Vercel must use a remote Postgres URL. Do not use localhost or 127.0.0.1 in Vercel.
# DATABASE_URL=file:./dev.db
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
