# Required: Google Gemini API key for chatbot AI features
GEMINI_API_KEY=

# Admin dashboard login (comma-separated emails allowed)
ADMIN_EMAILS=admin@example.com
ADMIN_PASSWORD=

# App URL used in email links (set to your Vercel URL in production)
APP_URL=http://localhost:3000

# SMTP email notifications (optional — ticket emails are skipped if not configured)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Email address that receives new-ticket admin alerts
SUPPORT_ALERT_EMAIL=

# Database path (optional — defaults to dev.db locally, /tmp on Vercel)
# DATABASE_URL=file:./dev.db
